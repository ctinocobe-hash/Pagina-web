# Copia este archivo como .env y llena los valores

# URL de tu proyecto Supabase (mismo que VITE_SUPABASE_URL)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clave anon pública de Supabase (mismo que VITE_SUPABASE_ANON_KEY)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Puerto del servidor local (el dashboard lo llama en este puerto)
PORT=3001

# Orígenes permitidos por CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,https://app.tinoco.legal

# Clave para encriptar credenciales del portal judicial (genera una clave segura)
PORTAL_ENCRYPTION_KEY=
